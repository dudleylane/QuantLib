---
Language:        Cpp
Standard:        Latest


# Project style: BSD/Allman braces, 120-column limit, 4-space indent.
# Enforced in CI via the format.yml workflow (clang-format --dry-run -Werror).
# Pinned to clang-format 22.x; LLVM-style defaults shift across major
# versions, so use that version locally to avoid spurious diffs.


# General appearance:

BasedOnStyle: LLVM

BreakBeforeBraces: Allman
IndentWidth: 4
ColumnLimit: 120
NamespaceIndentation: All
MaxEmptyLinesToKeep: 2
FixNamespaceComments: false

# Function declarations:

BinPackParameters: false
AllowShortFunctionsOnASingleLine: Inline
AlwaysBreakTemplateDeclarations: true

# T& x, not T &x:

DerivePointerAlignment: false
PointerAlignment: Left

# QuantLib headers first, then Boost, then std

SortIncludes: true
IncludeBlocks: Merge
IncludeCategories:
  - Regex:           '^"'
    Priority:        1
  - Regex:           '^<ql/'
    Priority:        2
  - Regex:           '^<boost/'
    Priority:        3
  - Regex:           '^<'
    Priority:        4

# Other:

AlignEscapedNewlines: Left
BreakBeforeTernaryOperators: false
ConstructorInitializerIndentWidth: 0
SortUsingDeclarations: false
IndentCaseLabels: true
IndentPPDirectives: AfterHash

...
